{
  "name": "accugeo-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "jest --ci --coverage --runInBand --testPathIgnorePatterns=\".*\\.integration\\.(test|spec)\\.[jt]sx?$\"",
    "test:integration": "jest --ci --runInBand --passWithNoTests --testMatch=\"**/?(*.)+(integration.test|integration.spec).[jt]s?(x)\" --json --outputFile=integration-test-results.json",
    "test:e2e": "playwright test --reporter=line,html --pass-with-no-tests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^14",
    "radix-ui": "^1.4.3",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "dependenciesMeta": {},
  "overrides": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^14",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
