# Copy this file to `.env.local` for local development.
# Never commit real secrets.

# Required: SendGrid API key (starts with SG.)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Required: mailbox that receives contact form messages
CONTACT_TO_EMAIL=you@yourdomain.com

# Optional: verified sender identity. If omitted, CONTACT_TO_EMAIL is used.
CONTACT_FROM_EMAIL=no-reply@yourdomain.com

# Optional rate-limit tuning
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=6
RATE_STORE_MAX_SIZE=5000
